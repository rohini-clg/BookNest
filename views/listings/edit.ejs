
<% layout("/layouts/boilerplate") %>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
    <title>Wanderlust</title>
  </head>
  <body>
    <h3>Edit your Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate
      class="needs-validation"
      enctype="multipart/form-data"
      >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
      <input name="listing[title]" 
      value="<%= listing.title %>"
       type="text" 
       class="form-control"
       required
       />
      <br /><br />
      <textarea name="listing[description]">
<%= listing.description %>required</textarea
      >
      <br /><br />



<div class="mb-3">
  Original Listing Image <br/>
<img src="<%= listing.image.url"%>
</div>

      <div class="mb-3">
        <label for="image" class="form-control">Image Link</label>
      <input name="listing[image]"
      type="file"
      class="form-control"
        required 
        />
      <br /><br />
      <input name="listing[price]" value="<%= listing.price %>" required type="number" />
      <br /><br />
      <input
        name="listing[country]"
        value="<%= listing.country %>"
        type="text"
        required
      />
      <br /><br />
      <input
        name="listing[location]"
        value="<%= listing.location %>"
        type="text"
        required
      />
      <br /><br />
      <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
   